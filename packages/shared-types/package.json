{
  "name": "@nairarails/shared-types",
  "version": "0.0.0",
  "private": true,
  "description": "Shared Zod schemas and TypeScript types for NairaRails",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "type-check": "tsc -b --dry",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@nairarails/tsconfig": "workspace:*",
    "typescript": "^5.7.3"
  }
}
