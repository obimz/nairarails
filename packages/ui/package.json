{
  "name": "@nairarails/ui",
  "version": "0.0.0",
  "private": true,
  "description": "Shared React component library for NairaRails — Phase 7",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types":  "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build":      "tsc -b",
    "dev":        "tsc -b --watch",
    "type-check": "tsc -b --dry",
    "clean":      "rm -rf dist"
  },
  "peerDependencies": {
    "react":     "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@nairarails/tsconfig": "workspace:*",
    "@types/node":          "^22.15.30",
    "@types/react":         "^19.1.8",
    "@types/react-dom":     "^19.1.5",
    "typescript":           "^5.7.3"
  }
}
