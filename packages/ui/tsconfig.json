{
  "extends": "@nairarails/tsconfig/base.json",
  "compilerOptions": {
    "outDir":           "./dist",
    "rootDir":          "./src",
    "composite":        true,
    "module":           "ESNext",
    "moduleResolution": "Bundler",
    "lib":              ["ES2022", "DOM", "DOM.Iterable"],
    "jsx":              "react-jsx"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
