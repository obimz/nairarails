// Prisma schema for NairaRails
// Run `pnpm --filter @nairarails/api db:push` to apply to Supabase (dev)
// Run `pnpm --filter @nairarails/api db:migrate` to apply migrations (prod)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  // Both point to the same PgBouncer pooler (port 6543) — port 5432 is blocked
  // on the current network. pgbouncer=true on the URL disables prepared statements.
}

// ─── Orders ───────────────────────────────────────────────────────────────────
// One row per payment order. The virtual account NUBAN is stored here once
// Nomba returns it from POST /accounts/virtual.
model Order {
  id                    Int      @id @default(autoincrement())
  orderRef              String   @unique @map("order_ref")
  customerName          String   @map("customer_name")
  customerEmail         String?  @map("customer_email")

  /// Amount the order was created with — stored in kobo (never naira floats)
  expectedAmountKobo    BigInt   @map("expected_amount_kobo")

  /// Amount actually received via the virtual account — null until funded
  receivedAmountKobo    BigInt?  @map("received_amount_kobo")

  currency              String   @default("NGN")
  status                OrderStatus @default(pending)

  virtualAccountNumber  String?  @map("virtual_account_number")
  bankName              String?  @map("bank_name")
  bankCode              String?  @map("bank_code")

  /// Sender details captured from the webhook — needed for refunds
  senderAccountNumber   String?  @map("sender_account_number")
  senderBankCode        String?  @map("sender_bank_code")
  senderName            String?  @map("sender_name")

  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  splits                Split[]
  ledgerEntries         LedgerEntry[]
  merchantId            String   @map("merchant_id")
  merchant              Merchant @relation(fields: [merchantId], references: [id], onDelete: Restrict)

  @@map("orders")
}

// ─── Merchants ───────────────────────────────────────────────────────────────
// One row per marketplace merchant integrating with NairaRails.
model Merchant {
  id            String   @id @default(cuid()) @map("id")
  name          String   @map("name")
  email         String   @unique @map("email")
  webhookUrl    String?  @map("webhook_url")

  /// Supabase Auth user ID — links this merchant row to their auth identity
  supabaseUid   String?  @unique @map("supabase_uid")
  /// False until the merchant clicks the verification link in their signup email
  emailVerified Boolean  @default(false) @map("email_verified")

  /// API key stored as SHA-256 hash — plaintext is shown once at issuance, never stored
  apiKeyHash    String?  @unique @map("api_key_hash")
  /// First 20 chars of the prefixed key, for display only (e.g. "nrk_live_3f9a2c1b…")
  apiKeyPrefix  String?  @map("api_key_prefix")
  apiKeyIssuedAt  DateTime? @map("api_key_issued_at")
  /// Null = never expires. Set via keys/rotate or keys/issue to add a hard expiry.
  apiKeyExpiresAt DateTime? @map("api_key_expires_at")

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  orders        Order[]

  @@map("merchants")
}

enum OrderStatus {
  pending
  paid
  underpayment
  overpayment
  unmatched
  expired       // VA expired with no payment received — terminal state, no further action expected
  refunded      // full or partial refund issued, order closed

  @@map("order_status")
}

// ─── Splits ───────────────────────────────────────────────────────────────────
// One row per party per order. Percentage and calculated kobo amount are both
// stored so we have an audit trail of what was intended vs what was sent.
model Split {
  id                  Int         @id @default(autoincrement())
  orderRef            String      @map("order_ref")
  party               String
  accountNumber       String      @map("account_number")
  bankCode            String      @map("bank_code")
  percentage          Int         // 1–100, all splits for an order sum to 100
  /// Calculated kobo amount — null until splits are executed
  amountKobo          BigInt?     @map("amount_kobo")
  status              SplitStatus @default(pending)
  /// Nomba transfer reference, set once the payout is initiated
  nombaTransferRef    String?     @map("nomba_transfer_ref")
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt @map("updated_at")

  order               Order       @relation(fields: [orderRef], references: [orderRef], onDelete: Cascade)

  @@map("splits")
}

enum SplitStatus {
  pending
  executed
  blocked
  failed

  @@map("split_status")
}

// ─── Ledger Entries ───────────────────────────────────────────────────────────
// Append-only log of every money movement tied to an order.
// Never update or delete rows here — only insert.
model LedgerEntry {
  id           Int              @id @default(autoincrement())
  orderRef     String           @map("order_ref")
  entryType    LedgerEntryType  @map("entry_type")
  /// Amount in kobo — positive for credits, negative for debits
  amountKobo   BigInt           @map("amount_kobo")
  currency     String           @default("NGN")
  reference    String?          // Nomba transaction reference
  narration    String?
  createdAt    DateTime         @default(now()) @map("created_at")

  order        Order            @relation(fields: [orderRef], references: [orderRef], onDelete: Restrict)

  @@map("ledger_entries")
}

enum LedgerEntryType {
  payment_received
  split_payout
  refund_issued
  adjustment

  @@map("ledger_entry_type")
}

// ─── Webhook Events ───────────────────────────────────────────────────────────
// Every inbound Nomba webhook is persisted here before any business logic runs.
// The unique constraint on requestId is the DB-level idempotency guarantee —
// a duplicate delivery will fail the INSERT and be caught before any side effects.
model WebhookEvent {
  id          Int      @id @default(autoincrement())
  /// Nomba's stable per-event ID — unique constraint enforces idempotency
  requestId   String   @unique @map("request_id")
  eventType   String   @map("event_type")
  /// Raw JSON payload stored as a string for auditability
  rawPayload  String   @map("raw_payload") @db.Text
  processedAt DateTime? @map("processed_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("webhook_events")
}
