PORT=3000
NODE_ENV=production
NOMBA_BASE_URL=https://api.nomba.com/v1
NOMBA_CLIENT_ID=
NOMBA_CLIENT_SECRET=
NOMBA_ACCOUNT_ID=
NOMBA_SUB_ACCOUNT_ID=
NOMBA_WEBHOOK_SECRET=
DATABASE_URL=
DIRECT_URL=
ADMIN_SECRET=
FRONTEND_URL=http://localhost:5173
VITE_API_BASE=http://localhost:3000

# ── Supabase Auth (Phase E) ───────────────────────────────────────────────────
# Server-side only — NEVER expose SUPABASE_SERVICE_ROLE_KEY to the frontend
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Public — safe to include in the frontend bundle
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Rate Limiting (Phase 16) ──────────────────────────────────────────────────
# Redis URL for distributed rate limiting. Use Upstash (free tier) or Railway Redis.
# If not set, falls back to in-memory store (not production-safe across multiple instances).
REDIS_URL=
# ── Demo / seed ───────────────────────────────────────────────────────────────
# Fixed API key for the seed merchant created by seed.ts.
# DEMO ONLY — not a real credential. Never use this value in production.
DEMO_MERCHANT_API_KEY=nrk_live_demo_seed_key

# Optional: point this at a webhook.site or requestbin URL to observe outbound
# payment.classified notifications during a live demo.
# Leave blank to skip outbound notifications for the seed merchant.
DEMO_MERCHANT_WEBHOOK_URL=
