# ─── NairaRails Environment Variables ────────────────────────────────────────
# Copy this file to .env and fill in all values before running the project.
# Never commit .env — it is gitignored.
#
# Run order:
#   1. Fill in DATABASE_URL / DIRECT_URL from your Supabase project settings
#   2. Fill in NOMBA_* from your Nomba sandbox dashboard
#   3. Fill in SUPABASE_* from your Supabase project settings
#   4. Fill in VITE_* — these are exposed to the browser bundle (frontend only)
#   5. GEMINI_API_KEY from https://aistudio.google.com/app/apikey (free tier)

# ─── Database (Supabase) ──────────────────────────────────────────────────────
# Both point to the same Supabase Postgres instance.
# Use the "Transaction" pooler URL (port 6543) for DATABASE_URL — pgbouncer=true
# Use the "Session" pooler or direct URL for DIRECT_URL — used by Prisma migrations
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# ─── Nomba API ────────────────────────────────────────────────────────────────
NOMBA_BASE_URL=https://api.nomba.com/v1
NOMBA_CLIENT_ID=
NOMBA_CLIENT_SECRET=
# Parent account ID — sent as the accountId header on every Nomba request
NOMBA_ACCOUNT_ID=
# Sub-account ID — webhooks only fire when VAs are created via the sub-account route
NOMBA_SUB_ACCOUNT_ID=
# Webhook secret — used to verify HMAC-SHA256 signatures on inbound Nomba webhooks
NOMBA_WEBHOOK_SECRET=

# ─── Supabase (server-side) ───────────────────────────────────────────────────
# These are server-only — never expose to the frontend
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ─── Admin ────────────────────────────────────────────────────────────────────
# Secret required in the x-admin-secret header to access /api/v1/admin/* routes
ADMIN_SECRET=

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Used to sign merchant session tokens — generate with: openssl rand -hex 32
JWT_SECRET=

# ─── Redis (optional) ─────────────────────────────────────────────────────────
# If not set, rate limiter falls back to in-memory store (fine for dev, not prod)
REDIS_URL=

# ─── AI Support Chat ─────────────────────────────────────────────────────────
# Google Gemini API key — get one free at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ─── Demo / Seed ─────────────────────────────────────────────────────────────
# Set to a webhook.site URL to observe outbound payment notifications during demo
DEMO_MERCHANT_WEBHOOK_URL=

# ─── Frontend (VITE_*) ───────────────────────────────────────────────────────
# These are the ONLY variables exposed to the browser bundle.
# Must start with VITE_ — Vite strips everything else from the client build.

# URL of the running API — use localhost for dev, your Railway URL for prod
VITE_API_BASE=http://localhost:3000

# Supabase public keys — safe to expose to the browser (anon key has RLS)
VITE_SUPABASE_URL=https://[project-ref].supabase.co
VITE_SUPABASE_ANON_KEY=

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# Allowed CORS origin for the frontend — set to your Railway frontend URL in prod
FRONTEND_URL=http://localhost:5173
