# ── Demo / seed ───────────────────────────────────────────────────────────────
# Fixed API key for the seed merchant created by seed.ts.
# DEMO ONLY — not a real credential. Never use this value in production.
DEMO_MERCHANT_API_KEY=nrk_live_demo_seed_key

# Optional: point this at a webhook.site or requestbin URL to observe outbound
# payment.classified notifications during a live demo.
# Leave blank to skip outbound notifications for the seed merchant.
DEMO_MERCHANT_WEBHOOK_URL=
