# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Nomba API ───────────────────────────────────────────────────────────────
# Sandbox: https://sandbox.api.nomba.com/v1
# Production: https://api.nomba.com/v1
NOMBA_BASE_URL=https://sandbox.api.nomba.com/v1
NOMBA_CLIENT_ID=your_test_client_id
NOMBA_CLIENT_SECRET=your_test_client_secret
NOMBA_ACCOUNT_ID=your_parent_account_id
NOMBA_WEBHOOK_SECRET=your_webhook_secret

# ─── Database ────────────────────────────────────────────────────────────────
# Use Supabase session pooler (port 5432) for long-lived Express connections.
# Transaction pooler (port 6543) is for serverless — do NOT use it here.
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
DIRECT_URL=<your_direct_url>

# ─── Frontend ────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
VITE_API_BASE=http://localhost:3000
