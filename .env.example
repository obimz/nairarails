# ─── Backend (apps/api) Environment Variables ────────────────────────────────
PORT=3000
NODE_ENV=production

# Nomba API credentials
NOMBA_BASE_URL=
NOMBA_CLIENT_ID=
NOMBA_CLIENT_SECRET=
NOMBA_WEBHOOK_SECRET=

# Database (Supabase)
DATABASE_URL=SESSION POOLER

# CORS allowed origin — set to your deployed Vercel URL in production
FRONTEND_URL=http://localhost:5173

# ─── Frontend (apps/web) Environment Variables ────────────────────────────────
# Base URL for NairaRails API calls — set to your deployed Railway API URL in production
# Example production value: https://your-api.railway.app
VITE_API_BASE=http://localhost:3000
